{
  "name": "theta-python",
  "version": "1.0.0",
  "description": "Python by THETA172 — Precision Python IDE",
  "author": "THETA172 / nothing frontend team",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently -k -s first -n VITE,ELECTRON -c cyan,magenta \"vite\" \"npx wait-on tcp:5173 -t 15000 && npm run electron:start\"",
    "electron:build": "vite build && electron-builder --win --x64",
    "electron:build:dir": "vite build && electron-builder --win --x64 --dir",
    "electron:preview": "vite build && cross-env NODE_ENV=production electron .",
    "relay:start": "node relay-server/index.js"
  },
  "build": {
    "appId": "com.theta172.python",
    "productName": "Python by THETA172",
    "copyright": "Copyright © 2025 THETA172",
    "asar": true,
    "asarUnpack": [
      "node_modules/bonjour-service/**/*",
      "node_modules/ws/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build-assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,LICENSE,license,LICENCE}",
      "!**/*.{ts,map,md}",
      "!relay-server/**/*",
      "!scripts/**/*",
      "!src/**/*",
      "!public/**/*",
      "!.git/**/*",
      "!.github/**/*",
      "!.gitignore",
      "!vite.config.js"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Python-by-THETA172-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Python by THETA172",
      "uninstallDisplayName": "Python by THETA172",
      "installerIcon": "build-assets/icon.ico",
      "uninstallerIcon": "build-assets/icon.ico",
      "installerHeader": "build-assets/installer-header.bmp",
      "installerSidebar": "build-assets/installer-sidebar.bmp",
      "installerHeaderIcon": "build-assets/icon.ico",
      "menuCategory": "THETA172",
      "license": null,
      "runAfterFinish": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build-assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "artifactName": "Python-by-THETA172-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "Python by THETA172",
      "icon": "build-assets/icon.icns",
      "iconSize": 80,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190,
          "type": "file"
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "build-assets/icon.png"
    }
  },
  "devDependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.0",
    "@replit/codemirror-minimap": "^0.5.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "gsap": "^3.15.0",
    "lib0": "^0.2.117",
    "png-to-ico": "^3.0.1",
    "puppeteer": "^25.1.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "dependencies": {
    "bonjour-service": "^1.4.0",
    "ws": "^8.21.0"
  }
}
